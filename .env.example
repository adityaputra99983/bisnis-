# =============================================================
# TEMPLATE ENVIRONMENT VARIABLES UNTUK BISNIS DJANGO
# Salin file ini jadi `.env` di development, atau set di dashboard
# hosting (Hostinger hPanel / Vercel Project Settings).
# =============================================================

# --- WAJIB DI PRODUCTION ---
# Generate baru: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# Atau pakai: https://djecrety.ir
SECRET_KEY=django-insecure-GANTI-DENGAN-RANDOM-SECRET-KEY-50-PANJANG

# DEBUG: default True untuk development.
# WAJIB set DEBUG=False di hosting dashboard (Hostinger hPanel / Vercel env)
# untuk production! Jika tidak, akan ada SSL redirect, HSTS, dan security headers aktif.
DEBUG=True

# Domain yang diizinkan (pisahkan koma). Untuk production, isi domain kamu.
# Format: leading dot (.) = wildcard subdomain. Contoh:
#   .vercel.app        → match bisnis-xxx.vercel.app, pr-123-bisnis-xxx.vercel.app
#   .yourdomain.com    → match app.yourdomain.com, www.yourdomain.com
# Untuk custom domain: tambahkan manual, misal yourdomain.com,www.yourdomain.com
# Default sudah include localhost + .vercel.app (cukup untuk Vercel deployment)
ALLOWED_HOSTS=localhost,127.0.0.1,.vercel.app,.localhost

# Domain untuk CSRF (wajib di HTTPS / production). Pisahkan koma.
# Contoh: https://yourdomain.com,https://www.yourdomain.com
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# --- DATABASE ---
# Kosongkan untuk SQLite (default: db.sqlite3) - cocok untuk Hostinger & development.
# Untuk Vercel/serverless WAJIB isi DATABASE_URL PostgreSQL/Supabase/Neon.
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
# Contoh: postgres://user:pass@db.supabase.co:5432/postgres
DATABASE_URL=

# --- STATIC & MEDIA FILES ---
# Biarkan kosong untuk pakai local filesystem (Hostinger & dev).
# Untuk Vercel/serverless WAJIB set CLOUDINARY_* (karena filesystem tidak persistent).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_STORAGE=

# --- PAYMENT ACCOUNTS (opsional, sudah ada default) ---
PAY_BCA_NUMBER=8808-1234-5678
PAY_BCA_NAME=Bali Tattoo Studio
PAY_MANDIRI_NUMBER=157-00-1234567-8
PAY_MANDIRI_NAME=Bali Tattoo Studio
PAY_BNI_NUMBER=8808-1234-5678-901
PAY_BNI_NAME=Bali Tattoo Studio
PAY_BRI_NUMBER=0123-01-123456-50-9
PAY_BRI_NAME=Bali Tattoo Studio
PAY_PERMATA_NUMBER=8808-123456
PAY_PERMATA_NAME=Bali Tattoo Studio
PAY_CIMB_NUMBER=8808-1234-56
PAY_CIMB_NAME=Bali Tattoo Studio
PAY_GOPAY_NUMBER=081234567890
PAY_GOPAY_NAME=Bali Tattoo Studio
PAY_OVO_NUMBER=081234567890
PAY_OVO_NAME=Bali Tattoo Studio
PAY_DANA_NUMBER=081234567890
PAY_DANA_NAME=Bali Tattoo Studio
PAY_SHOPEE_NUMBER=081234567890
PAY_SHOPEE_NAME=Bali Tattoo Studio
PAY_LINKAJA_NUMBER=081234567890
PAY_LINKAJA_NAME=Bali Tattoo Studio

# Batas waktu pembayaran (jam)
PAYMENT_EXPIRY_HOURS=24

# --- EMAIL (untuk notifikasi) - opsional ---
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# --- CORS (untuk REST API) ---
# Origin yang diizinkan akses API dari browser. Pisahkan koma.
# Default: kosong = CORS tertutup (hanya same-origin).
# Untuk mobile app: tidak perlu di-set (CORS hanya untuk browser).
# Untuk frontend SPA di domain lain: isi domain frontend.
# Contoh: https://app.yourdomain.com,https://admin.yourdomain.com
CORS_ALLOWED_ORIGINS=

# Regex tambahan untuk CORS (untuk pattern kompleks seperti subdomain dinamis).
# Pisahkan dengan double semicolon (;;). Default kosong.
# Contoh: ^https://[a-z0-9-]+\.yourdomain\.com$
CORS_ALLOWED_ORIGIN_REGEXES=

# Izinkan credentials (cookies/session) di CORS request. Default: False.
# Set True HANYA jika frontend pakai session auth (login via cookie).
# Untuk token-based (Bearer/Authorization header) biarkan False.
CORS_ALLOW_CREDENTIALS=False
