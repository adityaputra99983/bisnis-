{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "runtime": "python3.12"
      }
    }
  ],
  "buildCommand": "python manage.py collectstatic --noinput",
  "build": {
    "env": {
      "PYTHONUNBUFFERED": "1",
      "DJANGO_SETTINGS_MODULE": "bisnis.settings"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "env": {
    "PYTHONUNBUFFERED": "1",
    "DJANGO_SETTINGS_MODULE": "bisnis.settings"
  }
}
